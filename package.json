{
  "name": "vision-template-x",
  "version": "0.0.0",
  "scripts": {
    "start": "npm run start --prefix vision-template-x-frontend",
    "install-frontend": "npm install --prefix vision-template-x-frontend",
    "lint": "npm run lint --prefix vision-template-x-frontend",
    "build-frontend": "npm run build --prefix vision-template-x-frontend",
    "copy-frontend": "ncp 'vision-template-x-frontend/dist' 'dist'",
    "write-sbom": "npm run write-sbom-frontend",
    "write-sbom-frontend": "write-ur-packages ./vision-template-x-frontend/package-lock.json dist",
    "prebuild": "npm run clean-dist && npm run clean-target && npm run validate-manifest",
    "build-arm": "export ARCH=linux/arm64 && npm run build",
    "postinstall": "npm run install-frontend",
    "build": "npm run build-frontend",
    "prepackage": "mkdir dist && npm run copy-frontend && npm run copy-manifest && npm run copy-license && npm run write-sbom",
    "postbuild": "npm run package",
    "package": "package-urcap dist target",
    "copy-manifest": "ncp 'manifest.yaml' 'dist/manifest.yaml'",
    "copy-license": "ncp 'LICENSE' 'dist/LICENSE'",
    "clean-dist": "rimraf dist",
    "clean-target": "rimraf target",
    "install-urcap": "install-urcap 'target/vision-template-x*.urcapx' '../manifest-spec-19.10.31.json'",
    "delete-urcap": "delete-urcap funh vision-template-x",
    "validate-manifest": "validate-manifest 'manifest.yaml' '../manifest-spec-19.10.31.json'"
  },
  "private": true,
  "license": "Apache-2.0",
  "devDependencies": {
    "@universal-robots/urcap-utils": "2.1.2",
    "ncp": "2.0.0",
    "rimraf": "5.0.7"
  }
}
